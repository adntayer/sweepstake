{
    "$schema": "https://opencode.ai/config.json",
    "model": "DeepSeek V4 Flash Free",
    "autoupdate": false,
    "snapshot": false,
    "share": "disabled",
    "provider": {
        "google": {
            "npm": "@ai-sdk/google"
        },
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Local LLM",
            "options": {
                "baseURL": "http://127.0.0.1:8080"
            },
            "models": {
                "gemma-4-E4B-it-UD-Q6_K_XL.gguf": {
                    "name": "gemma-4-E4B-it-UD-Q6_K_XL.gguf",
                    "supportsToolCalls": true
                },
                "ai_Ornith-1.0-9B-Q4_K_M.gguf": {
                    "name": "ai_Ornith-1.0-9B-Q4_K_M.gguf",
                    "supportsToolCalls": true
                }
            }
        }
    },
    "permission": {
        "read": "allow",
        "edit": "allow",
        "grep": "allow",
        "glob": "allow",
        "skill": "allow",
        "websearch": "allow",
        "question": "allow",
        "webfetch": "allow",
        "bash": {
            "ss run 2026_world_cup": "allow",
            "ss": "allow",
            "Get-ChildItem": "allow",
            "Get-Content": "allow",
            "Get-Command": "allow",
            "Select-Object": "allow",
            "ForEach-Object": "allow",
            "Group-Object": "allow",
            "Sort-Object": "allow",
            "Import-Csv": "allow",
            "Test-Path": "allow",
            "python3": "allow",
            "python": "allow",
            "py": "allow",
            "Write-Output": "allow",
            "Select-String": "allow",
            "*": "ask"
        }
    }
}
